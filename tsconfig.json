{
    "compilerOptions": {
        "module": "es2022",
        "moduleResolution": "bundler",
        "target": "es2017",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": [
            "vite/client",
            "vitest/globals",
            "@types/jsdom",
            "@types/thunderbird-webext-browser"
        ]
    },
    "exclude": ["node_modules", "dist"]
}
